# Copy to .env (or pass as -e flags to docker run). All values optional except
# you SHOULD set a stable SHARDX_TOKEN_SECRET in production.

# Bind address.
SHARDX_BIND=0.0.0.0:8080

# Where the SQLite DB and snapshot blobs live (a Docker volume in production).
SHARDX_DATA_DIR=./data

# HS256 signing secret for auth tokens. If unset, a random one is generated at
# startup and ALL tokens become invalid on every restart — set a long, random,
# stable value in production.
SHARDX_TOKEN_SECRET=change-me-to-a-long-random-string

# Token lifetime in seconds (default 7 days).
SHARDX_TOKEN_TTL_SECS=604800

# Bootstrap admin, created only when the user table is empty (first run).
SHARDX_ADMIN_USER=admin
SHARDX_ADMIN_PASS=change-me
